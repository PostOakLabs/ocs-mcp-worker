{
  "name": "ocs-mcp",
  "main": "worker.mjs",
  "compatibility_date": "2026-05-01",
  "compatibility_flags": ["nodejs_compat"],
  "workers_dev": true,
  // Workers Logs — console output + autogenerated invocation logs. Already enabled in the
  // dashboard; declared here to keep local wrangler config in sync. Mirrors ainumbers-mcp.
  "observability": {
    "logs": {
      "enabled": true,
      "invocation_logs": true
    }
  },
  // Analytics Engine — queryable per-tool-call usage metrics, written centrally in the
  // fetch handler (mirrors ainumbers-mcp / apexlogics-mcp). Privacy: structural metadata
  // only — tool name, latency, ok/error, salted non-reversible caller hash; never the raw
  // query, parameters, outputs, or a reversible identity.
  "analytics_engine_datasets": [
    { "binding": "ANALYTICS", "dataset": "mcp_tool_calls" }
  ],
  "assets": {
    "directory": "./data",
    "binding": "ASSETS",
    "run_worker_first": true
  },
  "routes": [{ "pattern": "mcp.omegacentauri.me", "custom_domain": true }]
}
